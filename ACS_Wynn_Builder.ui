                </widget>
              </item>
              <item row="0" column="6">
                <widget class="QPushButton" name="btn_deploy">
                  <property name="minimumSize">
                    <size>
                      <width>88</width>
                      <height>34</height>
                    </size>
                  </property>
                  <property name="maximumSize">
                    <size>
                      <width>96</width>
                      <height>34</height>
                    </size>
                  </property>
                  <property name="text">
                    <string>DEPLOY</string>
                  </property>
                </widget>
              </item>
            </layout>
