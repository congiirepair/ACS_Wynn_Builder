        <!--
          SSH CARD — FIX (UI/UX): Restructured from a single cramped QHBoxLayout
          to a QGridLayout with two rows. Each field now has enough horizontal space
          to display its content without truncation at 750px window width.

          Row 0: [IP label] [IP field]   [USER label] [USER field]
          Row 1: [PASS label] [PASS field (colspan 1)] [DEPLOY button (colspan 1, right-aligned)]
        -->
        <item>
          <widget class="QFrame" name="card4">
            <layout class="QGridLayout" name="gridLayoutSSH">
              <property name="leftMargin">
                <number>10</number>
              </property>
              <property name="topMargin">
                <number>8</number>
              </property>
              <property name="rightMargin">
                <number>10</number>
              </property>
              <property name="bottomMargin">
                <number>8</number>
              </property>
              <property name="horizontalSpacing">
                <number>8</number>
              </property>
              <property name="verticalSpacing">
                <number>6</number>
              </property>

              <!-- Single row: IP + User + Pass + Deploy -->
              <item row="0" column="0">
                <widget class="QLabel" name="label_ip">
                  <property name="text">
                    <string>IP:</string>
                  </property>
                  <property name="minimumSize">
                    <size>
                      <width>40</width>
                      <height>0</height>
                    </size>
                  </property>
                </widget>
              </item>
              <item row="0" column="1">
                <widget class="QLineEdit" name="entry_ip">
                  <property name="maximumSize">
                    <size>
                      <width>140</width>
                      <height>16777215</height>
                    </size>
                  </property>
                </widget>
              </item>
              <item row="0" column="2">
                <widget class="QLabel" name="label_user">
                  <property name="text">
                    <string>USER:</string>
                  </property>
                  <property name="minimumSize">
                    <size>
                      <width>44</width>
                      <height>0</height>
                    </size>
                  </property>
                </widget>
              </item>
              <item row="0" column="3">
                <widget class="QLineEdit" name="entry_user">
                  <property name="maximumSize">
                    <size>
                      <width>95</width>
                      <height>16777215</height>
                    </size>
                  </property>
                </widget>
              </item>
              <item row="0" column="4">
                <widget class="QLabel" name="label_pass">
                  <property name="text">
                    <string>PASS:</string>
                  </property>
                </widget>
              </item>
              <item row="0" column="5">
                <widget class="QLineEdit" name="entry_ssh_pass">
                  <property name="maximumSize">
                    <size>
                      <width>170</width>
                      <height>16777215</height>
                    </size>
                  </property>
                  <property name="echoMode">
